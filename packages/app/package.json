{
  "name": "app",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "typecheck": "tsc --noEmit",
    "typecheck:worker": "tsc -p ./src/worker/tsconfig.json --noEmit",
    "typecheck:client": "vue-tsc -p ./src/client/tsconfig.json --noEmit",
    "typecheck:sw": "tsc -p ./src/sw/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:worker": "vitest run --config vitest.worker.config.ts",
    "test:worker:watch": "vitest --config vitest.worker.config.ts",
    "eslint": "eslint src/worker/",
    "eslint:fix": "eslint src/worker/ --fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply cfw-fileup-db --local",
    "db:reset": "rm -rf .wrangler/state/v3/d1",
    "cf-typegen": "wrangler types ./src/worker/worker-configuration.d.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:fresh": "pnpm db:reset && pnpm db:migrate:local && pnpm test:e2e"
  },
  "dependencies": {
    "@vuetify/v0": "1.0.0-alpha.4",
    "bgzf": "workspace:*",
    "file-type": "^22.0.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.3",
    "@cloudflare/vitest-pool-workers": "^0.16.4",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@misskey-dev/eslint-plugin": "^2.2.0",
    "@playwright/test": "1.56.1",
    "@types/node": "^25.7.0",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.1",
    "eventemitter3": "^5.0.4",
    "hono": "^4.12.18",
    "nanoid": "^5.1.11",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.6",
    "vue": "^3.5.34",
    "vue-tsc": "^3.2.8",
    "workbox-window": "^7.4.1",
    "wrangler": "^4.4.0"
  }
}
