{
  "name": "app",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "typecheck:worker": "tsc -p ./tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:worker": "vitest run --config vitest.worker.config.ts",
    "test:worker:watch": "vitest --config vitest.worker.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply cfw-fileup-db --local",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "bgzf": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.3",
    "@cloudflare/vitest-pool-workers": "^0.16.4",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@misskey-dev/eslint-plugin": "^2.2.0",
    "@types/node": "^25.7.0",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.1",
    "hono": "^4.12.18",
    "nanoid": "^5.1.11",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6",
    "vue": "^3.5.34",
    "wrangler": "^4.4.0"
  }
}
